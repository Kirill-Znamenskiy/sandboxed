{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "*": "ask",
        "question": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "external_directory": "ask",
        "read": "allow",
        "edit": "allow",
        "bash": {
            "*": "ask",
            "ls *": "allow",
            "git status *": "allow",
            "git diff *": "allow",
            "git log *": "allow",
            "pnpm test *": "allow",
