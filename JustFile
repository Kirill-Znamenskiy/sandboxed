SANDBOXED_DIR := justfile_directory()

default: list

list:
    @just --justfile '{{SANDBOXED_DIR}}/JustFile' --list --unsorted

# Safe checks only: no container build/run.
check: check-static check-config-opencode check-locks-override-opencode check-command-opencode

check-static:
    #!/usr/bin/env bash
    set -euo pipefail
    cd '{{SANDBOXED_DIR}}'

    bash -n src/sandboxed.sh

    python3 -c 'from pathlib import Path; [compile(Path(path).read_text(encoding="utf-8"), path, "exec") for path in ["src/sandboxed-config.py"]]'
    python3 -c 'from pathlib import Path; import yaml; path="targets/opencode/compose.yaml"; data=yaml.safe_load(Path(path).read_text(encoding="utf-8")); assert isinstance(data, dict), f"Expected YAML mapping in {path}"'
    printf '%s\n' 'OK check-static'

check-config-opencode:
    #!/usr/bin/env bash
    set -euo pipefail
    sandboxed_dir='{{SANDBOXED_DIR}}'
    tmp_dir="$(mktemp -d)"
    trap 'rm -rf "$tmp_dir"' EXIT

    mkdir -p "$tmp_dir/project"
    cd "$tmp_dir/project"

    SANDBOXED_HOME="$sandboxed_dir" \
    XDG_CONFIG_HOME="$tmp_dir/config" \
    XDG_DATA_HOME="$tmp_dir/data" \
    XDG_CACHE_HOME="$tmp_dir/cache" \
    XDG_STATE_HOME="$tmp_dir/state" \
        "$sandboxed_dir/src/sandboxed.sh" --just-print=config opencode > "$tmp_dir/config.yaml"

    python3 -c 'from pathlib import Path; import os, sys, yaml; data=yaml.safe_load(Path(sys.argv[1]).read_text(encoding="utf-8")); sandboxed_dir=Path(sys.argv[2]); levels={level["name"]: level for level in data["levels"]}; service=data["compose"]["services"]["sandboxed"]; sandboxed=data["compose"]["x-sandboxed"]; build_args=service["build"].get("args", {}); assert data["target"] == "opencode", "Unexpected target in printed config"; assert data["dockerfile"] == str(sandboxed_dir / "targets" / "opencode" / "Dockerfile"), "Unexpected Dockerfile path in printed config"; assert levels["install"]["compose_exists"], "Install-level opencode compose.yaml was not loaded"; assert build_args["WRK_USER_ID"] == str(os.getuid()), "Build user should match host UID"; assert build_args["WRK_GROUP_ID"] == str(os.getgid()), "Build group should match host GID"; assert service["command"] == ["opencode"], "Unexpected opencode command in effective config"; assert service["environment"]["HOME"] == "/home/wrkuser", "Unexpected container HOME"; assert sandboxed["symlinks"]["mode"] == "automount", "Unexpected symlink mode"; assert sandboxed["locks"]["enabled"] is True, "Unexpected lock check default"; assert sandboxed["locks"]["checks"], "Expected opencode lock checks"' "$tmp_dir/config.yaml" "$sandboxed_dir"
    printf '%s\n' 'OK check-config-opencode'

check-locks-override-opencode:
    #!/usr/bin/env bash
    set -euo pipefail
    sandboxed_dir='{{SANDBOXED_DIR}}'
    tmp_dir="$(mktemp -d)"
    trap 'rm -rf "$tmp_dir"' EXIT

    mkdir -p "$tmp_dir/project/.sandboxed/opencode"
    printf '%s\n' \
        'x-sandboxed:' \
        '  locks:' \
        '    enabled: false' \
        > "$tmp_dir/project/.sandboxed/opencode/compose.yaml"
    cd "$tmp_dir/project"

    SANDBOXED_HOME="$sandboxed_dir" \
    XDG_CONFIG_HOME="$tmp_dir/config" \
    XDG_DATA_HOME="$tmp_dir/data" \
    XDG_CACHE_HOME="$tmp_dir/cache" \
    XDG_STATE_HOME="$tmp_dir/state" \
        "$sandboxed_dir/src/sandboxed.sh" --just-print=config opencode > "$tmp_dir/config.yaml"

    python3 -c 'from pathlib import Path; import sys, yaml; data=yaml.safe_load(Path(sys.argv[1]).read_text(encoding="utf-8")); locks=data["compose"]["x-sandboxed"]["locks"]; assert locks["enabled"] is False, "Project override should disable lock checks"; assert locks["checks"], "Project override should preserve inherited lock definitions"' "$tmp_dir/config.yaml"
    printf '%s\n' 'OK check-locks-override-opencode'

check-command-opencode:
    #!/usr/bin/env bash
    set -euo pipefail
    sandboxed_dir='{{SANDBOXED_DIR}}'
    tmp_dir="$(mktemp -d)"
    trap 'rm -rf "$tmp_dir"' EXIT

    mkdir -p "$tmp_dir/project"
    cd "$tmp_dir/project"

    SANDBOXED_HOME="$sandboxed_dir" \
    XDG_CONFIG_HOME="$tmp_dir/config" \
    XDG_CACHE_HOME="$tmp_dir/cache" \
    XDG_STATE_HOME="$tmp_dir/state" \
        "$sandboxed_dir/src/sandboxed.sh" --rebuild --just-print=commands --target opencode sh -c 'printf "sandboxed-smoke=ok\n"; id; pwd; printf "HOME=%s\n" "$HOME"; printf "XDG_CONFIG_HOME=%s\n" "$XDG_CONFIG_HOME"; command -v opencode; opencode --version; sudo -n true; printf "sudo=ok\n"' > "$tmp_dir/command.txt"

    python3 -c 'from pathlib import Path; import os, sys; command=Path(sys.argv[1]).read_text(encoding="utf-8"); uid=str(os.getuid()); gid=str(os.getgid()); required=[f"--tag localhost/sandboxed-podman-opencode:uid-{uid}", " run ", "--rm", "--userns keep-id", f"--user {uid}:{gid}", "--cap-drop ALL", "--cap-add SETUID", "--cap-add SETGID", "--workdir", "sh", "-c", "sandboxed-smoke=ok"]; missing=[item for item in required if item not in command]; assert not missing, f"Printed command is missing {missing!r}"; assert "--security-opt" not in command and "no-new-privileges" not in command, "Printed command must not disable inner-container sudo"' "$tmp_dir/command.txt"
    printf '%s\n' 'OK check-command-opencode'

print-config-opencode:
    #!/usr/bin/env bash
    set -euo pipefail
    cd '{{SANDBOXED_DIR}}'
    SANDBOXED_HOME='{{SANDBOXED_DIR}}' ./src/sandboxed.sh --just-print=config opencode

print-command-opencode:
    #!/usr/bin/env bash
    set -euo pipefail
    cd '{{SANDBOXED_DIR}}'
    SANDBOXED_HOME='{{SANDBOXED_DIR}}' ./src/sandboxed.sh --just-print=commands --target opencode sh -c 'printf "sandboxed-smoke=ok\n"; id; pwd; printf "HOME=%s\n" "$HOME"; printf "XDG_CONFIG_HOME=%s\n" "$XDG_CONFIG_HOME"; command -v opencode; opencode --version; sudo -n true; printf "sudo=ok\n"'

check-real-starts: check-real-start-opencode

# Explicit runtime smoke: may build an image and start a disposable container.
check-real-start-opencode:
    #!/usr/bin/env bash
    set -euo pipefail
    sandboxed_dir='{{SANDBOXED_DIR}}'
    tmp_dir="$(mktemp -d)"
    trap 'rm -rf "$tmp_dir"' EXIT

    mkdir -p "$tmp_dir/project/.sandboxed/opencode"
    printf '%s\n' \
        'services:' \
        '  sandboxed:' \
        '    volumes:' \
        '      - type: bind' \
        '        source: ${SANDBOXED_PROJECT_DIR}' \
        '        target: ${SANDBOXED_PROJECT_DIR}' \
        'x-sandboxed:' \
        '  symlinks:' \
        '    scan: []' \
        '  locks:' \
        '    enabled: false' \
        > "$tmp_dir/project/.sandboxed/opencode/compose.yaml"
    cd "$tmp_dir/project"

    SANDBOXED_HOME="$sandboxed_dir" \
        "$sandboxed_dir/src/sandboxed.sh" --target opencode sh -c 'set -eu; printf "sandboxed-smoke=ok\n"; id; pwd; printf "HOME=%s\n" "$HOME"; printf "XDG_CONFIG_HOME=%s\n" "$XDG_CONFIG_HOME"; command -v opencode; opencode --version; sudo -n true; printf "sudo=ok\n"'
    printf '%s\n' 'OK smoke-opencode-shell'

    SANDBOXED_HOME="$sandboxed_dir" \
        "$sandboxed_dir/src/sandboxed.sh" --target opencode opencode debug config > "$tmp_dir/opencode-debug-config.json"
    python3 -c 'from pathlib import Path; import json, sys; config=json.loads(Path(sys.argv[1]).read_text(encoding="utf-8")); assert isinstance(config, dict), "Expected opencode config object"; assert "agent" in config, "Expected agent section in opencode config"' "$tmp_dir/opencode-debug-config.json"
    printf '%s\n' 'opencode debug config:'
    python3 -c 'from pathlib import Path; import sys; print(Path(sys.argv[1]).read_text(encoding="utf-8"), end="")' "$tmp_dir/opencode-debug-config.json"
    printf '%s\n' 'OK smoke-opencode-debug-config'
